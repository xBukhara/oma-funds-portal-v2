# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Admin ────────────────────────────────────────────────────
# Strong random string — this IS your admin password
ADMIN_SECRET=change-this-to-a-long-random-string

# ── Gmail SMTP ───────────────────────────────────────────────
GMAIL_USER=statements@omafunds.com
# Generate at: Google Account → Security → 2-Step Verification → App Passwords
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Portal URL (no trailing slash) ──────────────────────────
NEXT_PUBLIC_PORTAL_URL=https://port.omafunds.com

# ── Next.js ──────────────────────────────────────────────────
NEXTAUTH_SECRET=another-long-random-string
